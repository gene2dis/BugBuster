/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    // nf-core module: FASTP (used via QC subworkflow)
    withName: '.*:FASTP' {
        ext.args = [
            "--unqualified_percent_limit ${params.fastp_unqualified_percent_limit}",
            "--cut_front",
            "--cut_front_window_size ${params.fastp_cut_front_window_size}",
            "--cut_front_mean_quality ${params.fastp_cut_front_mean_quality}",
            "--cut_right",
            "--cut_right_window_size ${params.fastp_cut_right_window_size}",
            "--cut_right_mean_quality ${params.fastp_cut_right_mean_quality}",
            "--detect_adapter_for_pe",
            "--n_base_limit ${params.fastp_n_base_limit}",
            "--trim_poly_g"
        ].join(' ').trim()
        publishDir = [
            [
                path: { "${params.output}/01_quality_control/fastp/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "*.{json,html,log}"
            ],
            [
                path: { "${params.output}/01_quality_control/fastp/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "*.fastp.fastq.gz",
                enabled: false  // Don't publish trimmed reads by default
            ]
        ]
    }

    // nf-core module: KRAKEN2 (aliased from KRAKEN2_KRAKEN2)
    withName: '.*:KRAKEN2' {
        ext.args = [
            "--confidence ${params.kraken_confidence}"
        ].join(' ').trim()
        publishDir = [
            path: { "${params.output}/02_taxonomy/kraken2" },
            mode: params.publish_dir_mode,
            pattern: "*report.txt",
            saveAs: { filename -> "${meta.id}_${filename}" }
        ]
    }

    // nf-core module: BRACKEN (aliased from BRACKEN_BRACKEN)
    withName: '.*:BRACKEN' {
        ext.args = [
            "-r ${params.bracken_read_len}",
            "-l ${params.bracken_tax_level}"
        ].join(' ').trim()
        publishDir = [
            path: { "${params.output}/02_taxonomy/bracken" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : "${meta.id}_${filename}" }
        ]
    }

    // Taxonomy reporting module
    withName: '.*:TAXONOMY_REPORT' {
        cpus   = 2
        memory = { 4.GB * task.attempt }
        time   = { 10.m * task.attempt }
    }

    // Phyloseq table generation module
    withName: '.*:TAXONOMY_PHYLOSEQ' {
        cpus   = 4
        memory = { 8.GB * task.attempt }
        time   = { 30.m * task.attempt }
        ext.format = 'both'  // Output format: 'tables', 'hdf5', or 'both'
    }

    // Optional R phyloseq converter module
    withName: '.*:PHYLOSEQ_CONVERTER' {
        cpus   = 1
        memory = { 4.GB * task.attempt }
        time   = { 20.m * task.attempt }  // Increased to allow phyloseq installation
        ext.validate = false  // Set to true to enable validation output
    }

    withName: BOWTIE2 {
        ext.args = [
            "--local",
            "--ma ${params.bowtie_ma}",
            "--mp ${params.bowtie_mp}",
            "--score-min ${params.bowtie_score_min}",
            "-k ${params.bowtie_k}",
            "-N ${params.bowtie_N}",
            "-L ${params.bowtie_L}",
            "-R ${params.bowtie_R}",
            "-i ${params.bowtie_i}"
        ].join(' ').trim()
        publishDir = [
            enabled: false  // Intermediate files - don't publish
        ]
    }

    withName: 'BOWTIE2_DECONTAMINATE' {
        ext.args = [
            "--ma ${params.bowtie_ma}",
            "--mp ${params.bowtie_mp}",
            "--score-min ${params.bowtie_score_min}",
            "-k ${params.bowtie_k}",
            "-N ${params.bowtie_N}",
            "-L ${params.bowtie_L}",
            "-R ${params.bowtie_R}",
            "-i ${params.bowtie_i}"
        ].join(' ')
        publishDir = [
            enabled: false  // Clean reads published via storeDir in module
        ]
    }

    withName: QFILTER {
        publishDir = [
            enabled: false  // Intermediate files - don't publish
        ]
    }

    withName: 'METACERBERUS_READS|METACERBERUS_CONTIGS|METACERBERUS_BINS_BATCH' {
        ext.args = [
            "--hmm ${params.metacerberus_hmm.split(',').collect{it.trim()}.join(' ')}",
            "--db-path ${params.metacerberus_db}",
            "--minscore ${params.metacerberus_minscore}",
            "--evalue ${params.metacerberus_evalue}"
        ].join(' ').trim()
    }

    withName: DEEPARG_BINS {
        ext.args = [
            "--min-prob ${params.deeparg_min_prob}",
            "--arg-alignment-identity ${params.deeparg_arg_alignment_identity}",
            "--arg-alignment-evalue ${params.deeparg_arg_alignment_evalue}",
            "--arg-alignment-overlap ${params.deeparg_arg_alignment_overlap}",
            "--arg-num-alignments-per-entry ${params.deeparg_arg_num_alignments_per_entry}",
            "--model-version ${params.deeparg_model_version}"
        ].join(' ').trim()
    }

    withName: DEEPARG_CONTIGS {
        ext.args = [
            "--min-prob ${params.deeparg_min_prob}",
            "--arg-alignment-identity ${params.deeparg_arg_alignment_identity}",
            "--arg-alignment-evalue ${params.deeparg_arg_alignment_evalue}",
            "--arg-alignment-overlap ${params.deeparg_arg_alignment_overlap}",
            "--arg-num-alignments-per-entry ${params.deeparg_arg_num_alignments_per_entry}",
            "--model-version ${params.deeparg_model_version}"
        ].join(' ').trim()
    }

    withName: METABAT2 {
        ext.args = [
	    "--minContig ${params.metabat_minContig}",
	    "--maxP ${params.metabat_maxP}",
	    "--minS ${params.metabat_minS}",
	    "--maxEdges ${params.metabat_maxEdges}",
	    "--pTNF ${params.metabat_pTNF}",
	    "--minCV ${params.metabat_minCV}",
	    "--minCVSum ${params.metabat_minCVSum}",
	    "--minClsSize ${params.metabat_minClsSize}",
	    "--seed 3"
        ].join(' ').trim()
    }

    withName: METABAT2_COASSEMBLY {
        ext.args = [
            "--minContig ${params.metabat_minContig}",
            "--maxP ${params.metabat_maxP}",
            "--minS ${params.metabat_minS}",
            "--maxEdges ${params.metabat_maxEdges}",
            "--pTNF ${params.metabat_pTNF}",
            "--minCV ${params.metabat_minCV}",
            "--minCVSum ${params.metabat_minCVSum}",
            "--minClsSize ${params.metabat_minClsSize}",
            "--seed 3"
        ].join(' ').trim()
    }

    // nf-core module: METABAT2 (aliased from METABAT2_METABAT2)
    withName: '.*:METABAT2' {
        ext.args = [
            "--minContig ${params.metabat_minContig}",
            "--maxP ${params.metabat_maxP}",
            "--minS ${params.metabat_minS}",
            "--maxEdges ${params.metabat_maxEdges}",
            "--minClsSize ${params.metabat_minClsSize}",
            "--seed 3"
        ].join(' ').trim()
        publishDir = [
            path: { "${params.output}/04_binning/per_sample/${meta.id}/raw_bins/metabat2" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // nf-core module: MEGAHIT (aliased as NFCORE_MEGAHIT in assembly.nf)
    withName: '.*:NFCORE_MEGAHIT' {
        ext.args = ''
        ext.args2 = ''  // pigz compression args
        publishDir = [
            path: { "${params.output}/03_assembly/per_sample/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.contigs.fa.gz"
        ]
    }

    // nf-core module: PRODIGAL (aliased as PRODIGAL_CONTIGS in main.nf)
    withName: '.*PRODIGAL_CONTIGS' {
        ext.args = '-p meta'
        publishDir = [
            path: { "${params.output}/05_arg_prediction/contig_level/prodigal/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // nf-core module: SAMTOOLS_INDEX
    withName: 'NFCORE_SAMTOOLS_INDEX' {
        ext.args = ''
        publishDir = [
            enabled: false  // Intermediate file, keep in work directory
        ]
    }

    // nf-core module: MULTIQC
    withName: 'NFCORE_MULTIQC' {
        ext.args = ''
        publishDir = [
            path: { "${params.output}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // Local modules - QC
    //
    // COUNT_READS - Read counting for QC
    withName: 'COUNT_READS' {
        publishDir = [
            enabled: false  // Intermediate file - counts included in READS_REPORT
        ]
    }

    withName: 'READS_REPORT' {
        publishDir = [
            [
                path: { "${params.output}/01_quality_control/summary" },
                mode: params.publish_dir_mode,
                pattern: '*.csv'
            ],
            [
                path: { "${params.output}/01_quality_control/summary" },
                mode: params.publish_dir_mode,
                pattern: '*.png'
            ]
        ]
    }

    //
    // Local modules - Taxonomy
    //
    withName: 'SOURMASH' {
        publishDir = [
            path: { "${params.output}/02_taxonomy/sourmash" },
            mode: params.publish_dir_mode,
            pattern: '*.with-lineages.csv'
        ]
    }

    withName: 'TAXONOMY_REPORT' {
        publishDir = [
            [
                path: { "${params.output}/01_quality_control/summary" },
                mode: params.publish_dir_mode,
                pattern: 'Reads_report.csv'
            ],
            [
                path: { "${params.output}/02_taxonomy/figures" },
                mode: params.publish_dir_mode,
                pattern: '*.png'
            ]
        ]
    }

    withName: 'TAXONOMY_PHYLOSEQ' {
        publishDir = [
            [
                path: { "${params.output}/02_taxonomy/tables" },
                mode: params.publish_dir_mode,
                pattern: '*.tsv'
            ],
            [
                path: { "${params.output}/02_taxonomy/phyloseq" },
                mode: params.publish_dir_mode,
                pattern: '*.h5'
            ],
            [
                path: { "${params.output}/02_taxonomy/figures" },
                mode: params.publish_dir_mode,
                pattern: '*.png'
            ]
        ]
    }

    withName: 'PHYLOSEQ_CONVERTER' {
        publishDir = [
            path: { "${params.output}/02_taxonomy/phyloseq" },
            mode: params.publish_dir_mode,
            pattern: '*.RDS'
        ]
    }

    //
    // Local modules - Assembly
    //
    // BOWTIE2_SAMTOOLS - Alignment for binning/contig analysis
    withName: 'BOWTIE2_SAMTOOLS' {
        publishDir = [
            enabled: false  // Intermediate file - BAM used for depth calculation and indexing
        ]
    }

    // BOWTIE2_SAMTOOLS_DEPTH - Alignment for bin coverage (coassembly)
    withName: 'BOWTIE2_SAMTOOLS_DEPTH' {
        publishDir = [
            enabled: false  // Intermediate file - BAM used for bin coverage calculation
        ]
    }

    // CONTIG_FILTER_SUMMARY - Assembly filtering summary
    withName: 'CONTIG_FILTER_SUMMARY' {
        publishDir = [
            enabled: false  // Summary information already captured in other reports
        ]
    }

    // Unified MEGAHIT process handles both per-sample and co-assembly modes
    withName: 'MEGAHIT' {
        publishDir = [
            path: { meta.id == 'coassembly' ? "${params.output}/03_assembly/coassembly" : "${params.output}/03_assembly/per_sample/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*_contigs.fa'
        ]
    }

    // Unified BBMAP process handles both per-sample and co-assembly modes
    withName: 'BBMAP' {
        publishDir = [
            [
                path: { meta.id == 'coassembly' ? "${params.output}/03_assembly/coassembly" : "${params.output}/03_assembly/per_sample/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: '*_filtered_contigs.fa'
            ],
            [
                path: { meta.id == 'coassembly' ? "${params.output}/03_assembly/coassembly" : "${params.output}/03_assembly/per_sample/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: '*_contig.stats'
            ]
        ]
    }

    //
    // Local modules - Binning
    //
    // CALCULATE_DEPTH - Depth calculation for MetaBAT2
    withName: 'CALCULATE_DEPTH' {
        publishDir = [
            enabled: false  // Intermediate file - depth consumed by MetaBAT2
        ]
    }

    // Unified binning modules - handle both per-sample and co-assembly modes
    //
    withName: 'METABAT2' {
        publishDir = [
            path: { meta.id == 'coassembly' ? 
                "${params.output}/04_binning/coassembly/raw_bins/metabat2" : 
                "${params.output}/04_binning/per_sample/${meta.id}/raw_bins/metabat2" },
            mode: params.publish_dir_mode,
            pattern: '*metabat_bins'
        ]
    }

    withName: 'SEMIBIN' {
        publishDir = [
            path: { meta.id == 'coassembly' ? 
                "${params.output}/04_binning/coassembly/raw_bins/semibin" : 
                "${params.output}/04_binning/per_sample/${meta.id}/raw_bins/semibin" },
            mode: params.publish_dir_mode,
            pattern: '*semibin_output_bins'
        ]
    }

    withName: 'COMEBIN' {
        publishDir = [
            path: { meta.id == 'coassembly' ? 
                "${params.output}/04_binning/coassembly/raw_bins/comebin" : 
                "${params.output}/04_binning/per_sample/${meta.id}/raw_bins/comebin" },
            mode: params.publish_dir_mode,
            pattern: '*_comebin_bins/comebin_res/comebin_res_bins'
        ]
    }

    withName: 'METAWRAP' {
        publishDir = [
            path: { meta.id == 'coassembly' ? 
                "${params.output}/04_binning/coassembly/refined_bins" : 
                "${params.output}/04_binning/per_sample/${meta.id}/refined_bins" },
            mode: params.publish_dir_mode,
            pattern: '*metawrap*bins'
        ]
    }

    withName: 'CHECKM2' {
        publishDir = [
            path: { meta.id == 'coassembly' ? 
                "${params.output}/04_binning/coassembly/quality/checkm2" : 
                "${params.output}/04_binning/per_sample/${meta.id}/quality/checkm2" },
            mode: params.publish_dir_mode,
            pattern: '*quality_report.tsv'
        ]
    }

    withName: 'GTDB_TK' {
        publishDir = [
            path: { meta.id == 'coassembly' ? 
                "${params.output}/04_binning/coassembly/taxonomy/gtdbtk" : 
                "${params.output}/04_binning/per_sample/${meta.id}/taxonomy/gtdbtk" },
            mode: params.publish_dir_mode,
            pattern: '*_gtdbtk_*'
        ]
    }

    withName: 'CHECKM2_BATCH' {
        publishDir = [
            path: { "${params.output}/04_binning/per_sample" },
            mode: params.publish_dir_mode,
            pattern: '*_*_quality_report.tsv',
            saveAs: { filename ->
                // Extract sample_id from filename: S10_Ago2021_metabat_quality_report.tsv
                def parts = filename.tokenize('_')
                def binnerIdx = parts.findLastIndexOf { part -> part in ['metabat', 'semibin', 'comebin', 'metawrap'] }
                if (binnerIdx > 0) {
                    def sample_id = parts[0..<binnerIdx].join('_')
                    return "${sample_id}/quality/checkm2/${filename}"
                }
                return null
            }
        ]
    }

    withName: 'GTDB_TK_BATCH' {
        publishDir = [
            path: { "${params.output}/04_binning/per_sample" },
            mode: params.publish_dir_mode,
            pattern: '*_gtdbtk_*.tsv',
            saveAs: { filename ->
                // Extract sample_id from filename: S10_Ago2021_gtdbtk_bac120.tsv
                def parts = filename.tokenize('_')
                def gtdbIdx = parts.findLastIndexOf { part -> part == 'gtdbtk' }
                if (gtdbIdx > 0) {
                    def sample_id = parts[0..<gtdbIdx].join('_')
                    return "${sample_id}/taxonomy/gtdbtk/${filename}"
                }
                return null
            }
        ]
    }

    withName: 'BIN_QUALITY_REPORT' {
        publishDir = [
            [
                path: { "${params.output}/04_binning/quality/summary" },
                mode: params.publish_dir_mode,
                pattern: '*.png'
            ],
            [
                path: { "${params.output}/04_binning/quality/summary" },
                mode: params.publish_dir_mode,
                pattern: '*.csv'
            ]
        ]
    }

    withName: 'BIN_TAX_REPORT' {
        publishDir = [
            [
                path: { "${params.output}/04_binning/taxonomy/summary" },
                mode: params.publish_dir_mode,
                pattern: '*.png'
            ],
            [
                path: { "${params.output}/04_binning/taxonomy/summary" },
                mode: params.publish_dir_mode,
                pattern: '*.csv'
            ]
        ]
    }

    withName: 'BIN_SUMMARY' {
        publishDir = [
            path: { "${params.output}/04_binning/coassembly/summary" },
            mode: params.publish_dir_mode,
            pattern: 'Bin_summary.csv'
        ]
    }

    withName: 'BEDTOOLS' {
        publishDir = [
            path: { "${params.output}/04_binning/coassembly/coverage" },
            mode: params.publish_dir_mode,
            pattern: '*_bin_depth.tsv'
        ]
    }

    //
    // Local modules - ARG Prediction
    //
    withName: 'KARGA' {
        publishDir = [
            path: { "${params.output}/05_arg_prediction/read_level/karga" },
            mode: params.publish_dir_mode,
            pattern: '*_KARGA_mappedGenes.csv'
        ]
    }

    withName: 'KARGVA' {
        publishDir = [
            path: { "${params.output}/05_arg_prediction/read_level/kargva" },
            mode: params.publish_dir_mode,
            pattern: '*_KARGVA_mappedGenes.csv'
        ]
    }

    withName: 'ARGS_OAP' {
        publishDir = [
            path: { "${params.output}/05_arg_prediction/read_level/args_oap" },
            mode: params.publish_dir_mode,
            pattern: '*args_oap_s1_out'
        ]
    }

    withName: 'ARG_NORM_REPORT' {
        publishDir = [
            path: { "${params.output}/05_arg_prediction/read_level/summary" },
            mode: params.publish_dir_mode,
            pattern: '*.csv'
        ]
    }

    withName: 'DEEPARG_BINS' {
        publishDir = [
            path: { "${params.output}/05_arg_prediction/bin_level/deeparg/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*_deeparg_results'
        ]
    }

    withName: 'ARG_CONTIG_LEVEL_REPORT' {
        publishDir = [
            path: { "${params.output}/05_arg_prediction/contig_level/summary" },
            mode: params.publish_dir_mode,
            pattern: 'Contig_tax_and_arg_prediction.tsv'
        ]
    }

    withName: 'ARG_BLOBPLOT' {
        publishDir = [
            path: { "${params.output}/05_arg_prediction/contig_level/figures" },
            mode: params.publish_dir_mode,
            pattern: '*.png'
        ]
    }

    withName: 'CLUSTERING' {
        publishDir = [
            path: { "${params.output}/05_arg_prediction/bin_level/clustering" },
            mode: params.publish_dir_mode,
            pattern: '*_cluster.tsv'
        ]
    }

    withName: 'PRODIGAL_BINS' {
        publishDir = [
            path: { "${params.output}/05_arg_prediction/bin_level/proteins/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*_bins_proteins'
        ]
    }

    withName: 'PRODIGAL_CONTIGS' {
        publishDir = [
            path: { "${params.output}/05_arg_prediction/contig_level/prodigal/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*contigs*'
        ]
    }

    //
    // Local modules - Contig Taxonomy
    //
    // NT_BLASTN - BLAST against nt database for taxonomy
    withName: 'NT_BLASTN' {
        publishDir = [
            enabled: false  // Intermediate file - BLAST results consumed by BLOBTOOLS
        ]
    }

    // BLOBTOOLS - Generate blob tables for taxonomy visualization
    withName: 'BLOBTOOLS' {
        publishDir = [
            enabled: false  // Intermediate file - blob tables consumed by BLOBPLOT
        ]
    }

    withName: 'BLOBPLOT' {
        publishDir = [
            path: { "${params.output}/06_contig_taxonomy/figures" },
            mode: params.publish_dir_mode,
            pattern: '*.png'
        ]
    }

    //
    // Local modules - Functional Annotation
    //
    withName: 'METACERBERUS_READS' {
        publishDir = [
            path: { "${params.output}/07_functional_annotation/reads/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*_annotation_results'
        ]
    }

    withName: 'METACERBERUS_CONTIGS' {
        publishDir = [
            path: { "${params.output}/07_functional_annotation/contigs/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*_annotation_results'
        ]
    }

    withName: 'METACERBERUS_BINS_BATCH' {
        publishDir = [
            path: { "${params.output}/07_functional_annotation/bins" },
            mode: params.publish_dir_mode,
            pattern: '*_annotation_results'
        ]
    }

    //
    // Database modules
    //
    withName: 'FORMAT_SM_DB' {
        publishDir = [
            path: { "${params.databases_dir}/sourmash" },
            mode: params.publish_dir_mode,
            pattern: '*'
        ]
    }

    withName: 'FORMAT_KRAKEN_DB' {
        publishDir = [
            path: { "${params.databases_dir}/kraken" },
            mode: params.publish_dir_mode,
            pattern: '*'
        ]
    }

    withName: 'FORMAT_BOWTIE_INDEX' {
        publishDir = [
            path: { "${params.databases_dir}/bowtie_index" },
            mode: params.publish_dir_mode,
            pattern: '*'
        ]
    }

    withName: 'FORMAT_NT_BLAST_DB' {
        publishDir = [
            path: { "${params.databases_dir}/blast" },
            mode: params.publish_dir_mode,
            pattern: '*'
        ]
    }

    withName: 'FORMAT_TAXDUMP_FILES' {
        publishDir = [
            path: { "${params.databases_dir}/taxdump" },
            mode: params.publish_dir_mode,
            pattern: '*'
        ]
    }

    withName: 'DOWNLOAD_DEEPARG_DB' {
        publishDir = [
            path: { "${params.databases_dir}" },
            mode: params.publish_dir_mode,
            pattern: '*'
        ]
    }

    withName: 'FORMAT_CHECKM2_DB' {
        publishDir = [
            path: { "${params.databases_dir}/checkm2" },
            mode: params.publish_dir_mode,
            pattern: '*.dmnd'
        ]
    }

    withName: 'BOWTIE2_BUILD_COMBINED' {
        publishDir = [
            path: { "${params.databases_dir}/bowtie_index" },
            mode: params.publish_dir_mode,
            pattern: 'contaminants_index'
        ]
    }

    withName: 'BUILD_PHIX_BOWTIE2_INDEX' {
        publishDir = [
            path: { "${params.databases_dir}/bowtie_index" },
            mode: params.publish_dir_mode,
            pattern: 'phiX_index'
        ]
    }

    withName: 'DOWNLOAD_GTDBTK_DB' {
        publishDir = [
            path: { "${params.databases_dir}/gtdbtk" },
            mode: params.publish_dir_mode,
            pattern: '*'
        ]
    }

    withName: 'SOURMASH_TAX_PREPARE' {
        publishDir = [
            path: { "${params.databases_dir}/sourmash" },
            mode: params.publish_dir_mode,
            pattern: '*.sqldb'
        ]
    }

    //
    // RGI modules
    //
    withName: 'RGI_LOAD' {
        label = 'process_download'
        publishDir = [
            path: { "${params.databases_dir}/rgi" },
            mode: params.publish_dir_mode,
            pattern: 'card_db'
        ]
    }

    withName: 'RGI_LOAD_WILDCARD' {
        label = 'process_medium'
        publishDir = [
            path: { "${params.databases_dir}/rgi" },
            mode: params.publish_dir_mode,
            pattern: 'card_db_with_wildcard'
        ]
    }

    withName: 'RGI_BWT' {
        ext.args = ''
        time   = { check_max( 72.h * task.attempt, 'time' ) }
        errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
        maxRetries = 2
        publishDir = [
            [
                path: { "${params.output}/05_arg_prediction/read_level/rgi/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: '*.{txt,bam}'
            ]
        ]
    }

    withName: 'RGI_KMER' {
        ext.args = ''
        publishDir = [
            path: { "${params.output}/05_arg_prediction/read_level/rgi_kmer/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{json,txt}'
        ]
    }

    withName: 'RGI_REPORT' {
        publishDir = [
            [
                path: { "${params.output}/05_arg_prediction/read_level/rgi_summary" },
                mode: params.publish_dir_mode,
                pattern: '*.csv'
            ],
            [
                path: { "${params.output}/05_arg_prediction/read_level/rgi_summary" },
                mode: params.publish_dir_mode,
                pattern: '*.png'
            ]
        ]
    }
}
